[Unit]
Description=Resource Broker Service (RBS)
Documentation=https://gitcode.com/magickli/gta-rbs
After=network.target

[Service]
Type=simple
User=rbs
Group=rbs
WorkingDirectory=/var/lib/rbs
ExecStart=/usr/bin/rbs
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=rbs

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/rbs /var/log/rbs

# Resource limits
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
